# ============================================================
# DEFAULTS = DEV NATIVO NO HOST
# ============================================================
# Os hosts de servicos (mongo/redis/mcp) apontam para 127.0.0.1
# (localhost) porque o cenario padrao de desenvolvimento e:
#   - mongo + redis subindo em Docker
#   - backend + frontend rodando direto na maquina
#
# Quando o stack inteiro sobe via Docker Compose, o compose
# sobrescreve DATABASE_URL, REDIS_URL e MCP_SERVER_URL com os
# hosts internos da rede (mongo, redis, mcp). Nao precisa editar
# este arquivo ao trocar entre os modos.
#
# Configuracoes de DOMINIO (branding, locale, upload, paginacao,
# logos, IA, SMTP, S3) NAO vivem aqui. Vivem no documento Setting
# do MongoDB e sao editadas via UI /settings (usuario MASTER) ou
# pelo Setup Wizard no primeiro acesso.
# ============================================================

# ============================================
# AMBIENTE
# ============================================
# Ambiente de execucao (development | production | test)
NODE_ENV=development

# Porta interna do backend (nao altere, e a porta dentro do container)
PORT=3000

# Modo demo: quando "true", o seed `1778025600-demo-users.seed.ts` cria/atualiza
# os usuarios publicos da instancia demo (admin@admin.com / Admin@2026 e
# registered@registered.com / Registered@2026). Em qualquer outro valor o seed
# e no-op. Use "true" APENAS em instancias demo publicas — credenciais sao
# conhecidas e a senha e re-hashada a cada `npm run seed`.
DEMO_MODE=false

# ============================================
# BANCO DE DADOS MONGODB
# ============================================
# IMPORTANTE: Altere o usuario e senha do MongoDB em producao!
DB_USERNAME=lowcodejs
DB_PASSWORD=lowcodejs
DB_DATABASE=lowcodejs
DB_DATA_DATABASE=lowcodejs_data

# URL de conexao com MongoDB (host nativo).
# authSource=admin e necessario porque o usuario e criado no banco admin.
# Em compose, este valor e sobrescrito para usar host interno `mongo`.
DATABASE_URL=mongodb://lowcodejs:lowcodejs@127.0.0.1:27017/lowcodejs?authSource=admin

# ============================================
# PORTAS E URLS DA APLICACAO
# ============================================
# Porta do backend exposta no host
APP_SERVER_PORT=3000

# Porta do frontend exposta no host
APP_CLIENT_PORT=5173

# URLs publicas da aplicacao (ajuste para seu dominio em producao)
APP_SERVER_URL=http://localhost:3000
APP_CLIENT_URL=http://localhost:5173

# URL da API para o frontend (build-time variable)
VITE_API_BASE_URL=http://localhost:3000

# ============================================
# ARMAZENAMENTO
# ============================================
# Driver (local/S3) e credenciais ficam no documento Setting do MongoDB.
# Configure pelo Setup Wizard ou pela UI /settings (usuario MASTER).

# ============================================
# CORS - ORIGENS PERMITIDAS
# ============================================
# Origens extras permitidas para CORS (separadas por ponto e virgula)
# Suporta wildcard: *.dominio.com
# APP_SERVER_URL e APP_CLIENT_URL sao sempre permitidas automaticamente.
# Requer reinicio do servidor para aplicar mudancas.
# ALLOWED_ORIGINS=

# ============================================
# SEGURANCA - JWT E COOKIES
# ============================================
# ATENCAO: NUNCA use essas chaves em producao!
# Use o script credential-generator.sh para gerar novas chaves:
# ./credential-generator.sh
# Dominio dos cookies (ajuste para seu dominio em producao)
COOKIE_DOMAIN=localhost

# Chave privada JWT (RSA formato base64)
JWT_PRIVATE_KEY=GENERATE_YOUR_OWN_PRIVATE_KEY

# Chave publica JWT (RSA formato base64)
JWT_PUBLIC_KEY=GENERATE_YOUR_OWN_PUBLIC_KEY

# Secret para cookies (string aleatoria)
COOKIE_SECRET=GENERATE_YOUR_OWN_COOKIE_SECRET

# ============================================
# REDIS
# ============================================
# URL de conexao com Redis (host nativo).
# Em compose, este valor e sobrescrito para `redis://redis:6379`.
REDIS_URL=redis://localhost:6379

# ============================================
# WORKERS (BullMQ) - opcional
# ============================================
# Concorrencia dos workers em background. Schema usa default 5
# se ausente; descomente para ajustar.
# STORAGE_MIGRATION_CONCURRENCY=5
# EMAIL_WORKER_CONCURRENCY=5

# ============================================
# ASSISTENTE IA (Chat) - Opcional
# ============================================
# Para usar o Assistente IA:
#   1. Suba o container: docker compose --profile ai up -d
#   2. Configure a chave OpenAI via UI /settings (usuario MASTER)
#   3. Ative o toggle "Habilitar Assistente IA" nas Configuracoes
#
# Em compose, MCP_SERVER_URL e sobrescrito para `http://mcp:3000/mcp`.
MCP_SERVER_URL=http://localhost:3001/mcp
MCP_PORT=3001

# ============================================
# DOCKER COMPOSE PROFILES (servicos opcionais)
# ============================================
# Descomente para ativar servicos opcionais automaticamente:
# COMPOSE_PROFILES=ai
#
# Ou suba manualmente:
#   docker compose --profile ai up -d                 (Assistente IA)
