# ============================================
# AMBIENTE
# ============================================
# Ambiente de execução (development | production | test)
NODE_ENV=development

# Porta interna do backend (não altere, é a porta dentro do container)
PORT=3000

# ============================================
# BANCO DE DADOS MONGODB
# ============================================
# IMPORTANTE: Altere o usuário e senha do MongoDB em produção!
DB_USERNAME=lowcodejs
DB_PASSWORD=lowcodejs
DB_DATABASE=lowcodejs
DB_DATA_DATABASE=lowcodejs_data

# URL de conexão com MongoDB (ajuste o host se necessário)
# Para docker-compose: use "mongo" como host
# Para instalação local: use "localhost" ou IP do servidor
# authSource=admin é necessário porque o usuário é criado no banco admin
DATABASE_URL=mongodb://lowcodejs:lowcodejs@mongo:27017/lowcodejs?authSource=admin
# DATABASE_URL=mongodb://lowcodejs:lowcodejs@127.0.0.1:27017/lowcodejs?authSource=admin

# ============================================
# PORTAS E URLS DA APLICAÇÃO
# ============================================
# Porta do backend exposta no host
APP_SERVER_PORT=3000

# Porta do frontend exposta no host
APP_CLIENT_PORT=5173

# URLs públicas da aplicação (ajuste para seu domínio em produção)
APP_SERVER_URL=http://localhost:3000
APP_CLIENT_URL=http://localhost:5173

# URL da API para o frontend (build-time variable)
VITE_API_BASE_URL=http://localhost:3000

# ============================================
# ARMAZENAMENTO
# ============================================
# Armazenamento (local/S3) configurado via Setup Wizard ou Settings na UI
# Nenhuma variavel de ambiente necessaria — tudo gerenciado pelo banco

# ============================================
# CORS - ORIGENS PERMITIDAS
# ============================================
# Origens extras permitidas para CORS (separadas por ponto e vírgula)
# Suporta wildcard: *.dominio.com
# APP_SERVER_URL e APP_CLIENT_URL são sempre permitidas automaticamente
# Requer reinício do servidor para aplicar mudanças
# ALLOWED_ORIGINS=

# ============================================
# SEGURANÇA - JWT E COOKIES
# ============================================
# ATENÇÃO: NUNCA use essas chaves em produção!
# Use o script credential-generator.sh para gerar novas chaves:
# ./credential-generator.sh
# Domínio dos cookies (ajuste para seu domínio em produção)
COOKIE_DOMAIN=localhost

# Chave privada JWT (RSA formato base64)
JWT_PRIVATE_KEY=GENERATE_YOUR_OWN_PRIVATE_KEY

# Chave pública JWT (RSA formato base64)
JWT_PUBLIC_KEY=GENERATE_YOUR_OWN_PUBLIC_KEY

# Secret para cookies (string aleatória)
COOKIE_SECRET=GENERATE_YOUR_OWN_COOKIE_SECRET

# ============================================
# REDIS
# ============================================
# URL de conexão com Redis
# Para docker-compose: use "redis" como host
# Para instalação local: use "localhost" (default)
REDIS_URL=redis://redis:6379

# ============================================
# ASSISTENTE IA (Chat) - Opcional
# ============================================
# Para usar o Assistente IA:
#   1. Suba o container: docker compose --profile ai up -d
#   2. Configure a chave OpenAI via Settings na UI (menu Configuracoes, como MASTER)
#   3. Ative o toggle "Habilitar Assistente IA" nas Configuracoes
MCP_SERVER_URL=http://mcp:3000/mcp
MCP_PORT=3001

# ============================================
# DOCKER COMPOSE PROFILES (servicos opcionais)
# ============================================
# Descomente para ativar servicos opcionais automaticamente:
# COMPOSE_PROFILES=ai
#
# Ou suba manualmente:
#   docker compose --profile ai up -d                 (Assistente IA)
