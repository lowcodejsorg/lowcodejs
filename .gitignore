# Ignora node_modules em qualquer nível
**/node_modules/

# Ignora arquivos de build em qualquer pasta
**/dist/
**/build/

# Ignora arquivos de log em qualquer lugar
**/*.log

# Ignora arquivos específicos em subpastas
**/coverage/
**/.DS_Store
**/logs
**/.env
**/.env.test

# Ignora todos os arquivos em backend/_storage/
backend/_storage/*
# Mas mantém os logos
!backend/_storage/logo-large.webp
!backend/_storage/logo-small.webp

_docs/nextjs/
frontend-next

# Local docker overrides
docker-compose.override.yml

# Claude Code local settings (machine-specific permissions)
.claude/settings.json
.claude/settings.local.json

!backend/application/resources/logs/
!backend/application/resources/logs/**

!frontend/src/routes/_private/logs
!frontend/src/routes/_private/logs/**